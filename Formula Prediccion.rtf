\f0\b\fs32 \cf0 7. Pseudoc\'f3digo de la predicci\'f3n\
\pard\pardeftab560\slleading20\partightenfactor0

\f2\b0\fs24 \cf0 funci\'f3n estimar_precio(propiedad, coef):\
    p = coef.intercepto\
    p += coef.area        * propiedad.area\
    p += coef.edad        * propiedad.edad\
    p += coef.pisos       * propiedad.pisos\
    p += coef.banos       * propiedad.banos\
    p += coef.lote        * propiedad.lote\
    p += coef.dist_centro * propiedad.dist_centro\
    p += coef.anio        * propiedad.anio\
    devolver max(p, 0)        // un precio negativo se trunca a 0\
\pard\pardeftab560\slleading20\partightenfactor0

\f0\b\fs26 \cf0 Referencia en Python\
\pard\pardeftab560\slleading20\partightenfactor0

\f2\b0\fs24 \cf0 def estimar_precio(prop: dict, coef: dict) -> float:\
    p = coef["intercepto"]\
    for k in ["area","edad","pisos","banos","lote","dist_centro","anio"]:\
        p += coef[k] * prop[k]\
    return max(p, 0.0)\
\pard\pardeftab560\slleading20\partightenfactor0

\f0\b\fs26 \cf0 Referencia en JavaScript\
\pard\pardeftab560\slleading20\partightenfactor0

\f2\b0\fs24 \cf0 function estimarPrecio(prop, coef) \{\
  let p = coef.intercepto;\
  for (const k of ["area","edad","pisos","banos","lote","dist_centro","anio"]) \{\
    p += coef[k] * prop[k];\
  \}\
  return Math.max(p, 0);\
\}\
\pard\pardeftab560\slleading20\partightenfactor0

