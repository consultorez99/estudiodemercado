\f0\b\fs36 \cf0 \strokec2 7. Pseudoc\'f3digo de la predicci\'f3n\
\pard\pardeftab720\partightenfactor0

\f2\b0\fs26 \cf0 funci\'f3n estimar_precio(propiedad, modelo):\
    p = modelo.coeficientes_numericos.intercepto\
    p += modelo.coeficientes_numericos.area  * propiedad.area\
    p += modelo.coeficientes_numericos.edad  * propiedad.edad\
    p += modelo.coeficientes_numericos.pisos * propiedad.pisos\
    p += modelo.coeficientes_numericos.banos * propiedad.banos\
    p += modelo.coeficientes_numericos.lote  * propiedad.lote\
    p += modelo.coeficientes_numericos.anio  * propiedad.anio\
\
    // ajuste de zona: si la colonia no est\'e1 en el cat\'e1logo, se usa la de referencia (ajuste 0)\
    p += modelo.ajuste_colonia[propiedad.colonia]  ?? 0\
\
    si modelo.usa_distancia:\
        p += modelo.coeficiente_distancia_opcional * propiedad.dist_centro\
\
    devolver max(p, 0)\
\pard\pardeftab720\sa280\partightenfactor0

\f0\b\fs28 \cf0 Referencia en Python\
\pard\pardeftab720\partightenfactor0

\f2\b0\fs26 \cf0 def estimar_precio(prop: dict, modelo: dict) -> float:\
    c = modelo["coeficientes_numericos"]\
    p = c["intercepto"]\
    for k in ["area", "edad", "pisos", "banos", "lote", "anio"]:\
        p += c[k] * prop[k]\
    p += modelo["ajuste_colonia"].get(prop["colonia"], 0)   # zona desconocida -> referencia\
    if modelo.get("usa_distancia") and modelo.get("coeficiente_distancia_opcional"):\
        p += modelo["coeficiente_distancia_opcional"] * prop.get("dist_centro", 0)\
    return max(p, 0.0)\
\pard\pardeftab720\sa280\partightenfactor0

\f0\b\fs28 \cf0 Referencia en JavaScript\
\pard\pardeftab720\partightenfactor0

\f2\b0\fs26 \cf0 function estimarPrecio(prop, modelo) \{\
  const c = modelo.coeficientes_numericos;\
  let p = c.intercepto;\
  for (const k of ["area", "edad", "pisos", "banos", "lote", "anio"]) \{\
    p += c[k] * prop[k];\
  \}\
  p += modelo.ajuste_colonia[prop.colonia] ?? 0;   // zona desconocida -> referencia\
  if (modelo.usa_distancia && modelo.coeficiente_distancia_opcional) \{\
    p += modelo.coeficiente_distancia_opcional * (prop.dist_centro ?? 0);\
  \}\
  return Math.max(p, 0);\
\}\
\pard\pardeftab720\partightenfactor0

